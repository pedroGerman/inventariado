# Modo demo (sin Supabase). Para producción, quitar o comentar USE_MOCK.
# NEXT_PUBLIC_USE_MOCK=true

NEXT_PUBLIC_USE_MOCK=false

# Project URL — formato: https://TU_PROJECT_REF.supabase.co
# (NO uses la "Publishable key" aquí; esa va en ANON_KEY)
NEXT_PUBLIC_SUPABASE_URL=
# Anon / Publishable key (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opcional: URL pública de la app (confirmación de correo, redirects)
# Local: http://localhost:3000
# Prod:  https://inventariado-delta.vercel.app
NEXT_PUBLIC_SITE_URL=

# Correos con acceso al panel de comentarios (solo servidor, no expuesto al cliente).
# Deben coincidir con feedback_admin_allowlist o is_feedback_admin en Supabase.
# FEEDBACK_ADMIN_EMAILS=dueno@ejemplo.com,otro@ejemplo.com
